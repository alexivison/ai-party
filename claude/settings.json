{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Skill(*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(chgrp:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(cut:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(open:*)",
      "Bash(pwd:*)",
      "Bash(printf:*)",
      "Bash(rm:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(uniq:*)",
      "Bash(xargs:*)",
      "Bash(xxd:*)",
      "Bash(party-cli:*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__chrome-devtools__:*",
      "mcp__figma__*",
      "mcp__notion__*",
      "mcp__claude_ai_Linear__:*"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/node_modules/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/.next/**)",
      "Read(**/package-lock.json)",
      "Read(**/yarn.lock)",
      "Read(**/pnpm-lock.yaml)"
    ],
    "ask": [
      "Bash(gh pr close:*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-cleanup.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/register-agent-id.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-guard.sh 2>>~/.claude/logs/hook-debug-worktree-guard.log",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/codex-gate.sh 2>>~/.claude/logs/hook-debug-codex-gate.log",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pr-gate.sh 2>>~/.claude/logs/hook-debug-pr-gate.log",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/push-lint-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/wizard-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-trace-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-trace-stop.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/codex-trace.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-track.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-marker.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/status-line.sh"
  },
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "in-process",
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
